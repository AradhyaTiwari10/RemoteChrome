{
  "name": "browser-pilot",
  "version": "0.1.0",
  "private": true,
  "description": "BrowserPilot monorepo",
  "scripts": {
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev": "concurrently --kill-others \"npm run dev:frontend\" \"npm run dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
